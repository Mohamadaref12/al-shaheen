{
  "info": {
    "name": "Al-Shaheen",
    "description": "Al-Shaheen News Platform — REST API v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "{{base_url}}"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Reader",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.environment.set('token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/register",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Ahmed Reader\",\n  \"email\": \"reader@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"type\": \"reader\",\n  \"locale\": \"ar\"\n}"
            }
          }
        },
        {
          "name": "Register Contributor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.environment.set('token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/register",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Sara Contributor\",\n  \"email\": \"contributor@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"type\": \"contributor\",\n  \"locale\": \"ar\",\n  \"bio\": \"Passionate about journalism and media.\",\n  \"portfolio_link\": \"https://portfolio.example.com\",\n  \"profile_photo\": \"{{profile_photo_path}}\",\n  \"categories\": [1, 2]\n}"
            }
          }
        },
        {
          "name": "Register Writer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.environment.set('token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/register",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Omar Writer\",\n  \"email\": \"writer@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\",\n  \"type\": \"writer\",\n  \"locale\": \"ar\",\n  \"display_name\": \"Omar Al-Shaheen\",\n  \"bio\": \"Experienced journalist with 5 years in political reporting.\",\n  \"portfolio_link\": \"https://writer.example.com\",\n  \"profile_photo\": \"{{profile_photo_path}}\",\n  \"categories\": [1, 2],\n  \"experience_level\": \"senior\",\n  \"languages\": [\"Arabic\", \"English\"],\n  \"editorial_specialties\": [\"Politics\", \"Investigative\"]\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.environment.set('token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/login",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"Password@123\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Update Profile (Reader)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/auth/profile",
            "description": "Reader: user fields only — name, email, country, language, locale.",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Ahmed Reader Updated\",\n  \"country\": \"SA\",\n  \"language\": \"ar\",\n  \"locale\": \"ar\"\n}"
            }
          }
        },
        {
          "name": "Update Profile (Contributor)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/auth/profile",
            "description": "Contributor: user fields + bio, profile_photo, portfolio_link, categories. Upload profile image first (Uploads → Upload Profile Image).",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Sara Contributor Updated\",\n  \"country\": \"SA\",\n  \"locale\": \"ar\",\n  \"bio\": \"Updated contributor bio.\",\n  \"portfolio_link\": \"https://portfolio.example.com/sara\",\n  \"profile_photo\": \"{{profile_photo_path}}\",\n  \"categories\": [1, 2]\n}"
            }
          }
        },
        {
          "name": "Update Profile (Writer)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/auth/profile",
            "description": "Writer: user fields + display_name, bio, profile_photo, portfolio_link, experience_level, languages, editorial_specialties, location, social_links, media_affiliation, categories.",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"name\": \"Omar Writer\",\n  \"display_name\": \"Omar Al-Shaheen\",\n  \"bio\": \"Updated writer bio.\",\n  \"portfolio_link\": \"https://writer.example.com/omar\",\n  \"profile_photo\": \"{{profile_photo_path}}\",\n  \"experience_level\": \"senior\",\n  \"languages\": [\"Arabic\", \"English\"],\n  \"editorial_specialties\": [\"Politics\", \"Economy\"],\n  \"location\": \"Riyadh, SA\",\n  \"social_links\": {\n    \"twitter\": \"https://twitter.com/omar\",\n    \"linkedin\": \"https://linkedin.com/in/omar\"\n  },\n  \"media_affiliation\": \"Al-Shaheen Media\",\n  \"categories\": [1, 2]\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/auth/change-password",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"current_password\": \"Password@123\",\n  \"password\": \"NewPass@456\",\n  \"password_confirmation\": \"NewPass@456\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.environment.set('token', '');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
          "name": "Upload Profile Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.path) {",
                  "  pm.environment.set('profile_photo_path', res.data.path);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/uploads/images",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "profile", "type": "text", "description": "profile | featured | portfolio | general" },
                { "key": "image", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Upload Featured Image",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/uploads/images",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "featured", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Home",
      "item": [
        {
          "name": "Breaking News Ticker",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/home/breaking-news?locale=ar&limit=10",
              "host": ["{{base_url}}"],
              "path": ["home", "breaking-news"],
              "query": [
                { "key": "locale", "value": "ar", "description": "ar | en" },
                { "key": "limit", "value": "10", "description": "عدد العناوين (أقصى 20)" }
              ]
            }
          }
        },
        {
          "name": "Top 3 Articles",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/home/top-articles?locale=ar",
              "host": ["{{base_url}}"],
              "path": ["home", "top-articles"],
              "query": [
                { "key": "locale", "value": "ar", "description": "ar | en" },
                { "key": "category", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Trending Articles",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/home/trending-article?locale=ar&limit=6",
              "host": ["{{base_url}}"],
              "path": ["home", "trending-article"],
              "query": [
                { "key": "locale", "value": "ar" },
                { "key": "limit", "value": "6", "description": "عدد المقالات (أقصى 20)" },
                { "key": "category", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Editor Picks",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/home/editor-picks?locale=ar&limit=6",
              "host": ["{{base_url}}"],
              "path": ["home", "editor-picks"],
              "query": [
                { "key": "locale", "value": "ar" },
                { "key": "limit", "value": "6" },
                { "key": "category", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Filters",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/home/filters"
          }
        },
        {
          "name": "High-Performance Writers",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/home/writers?category_id=1&limit=5",
              "host": ["{{base_url}}"],
              "path": ["home", "writers"],
              "query": [
                { "key": "category_id", "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Articles",
      "item": [
        {
          "name": "List Articles",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/articles?per_page=15&sort=latest",
              "host": ["{{base_url}}"],
              "path": ["articles"],
              "query": [
                { "key": "per_page", "value": "15" },
                { "key": "sort", "value": "latest", "description": "latest | views | oldest" },
                { "key": "category", "value": "", "disabled": true },
                { "key": "tag", "value": "", "disabled": true },
                { "key": "locale", "value": "", "disabled": true, "description": "ar | en" },
                { "key": "breaking", "value": "true", "disabled": true },
                { "key": "premium", "value": "true", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Show Article",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/articles/{{article_id}}"
          }
        },
        {
          "name": "Related Stories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/articles/{{article_id}}/related"
          }
        },
        {
          "name": "Trending Topics",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/articles/{{article_id}}/trending-topics"
          }
        },
        {
          "name": "Next Read",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/articles/{{article_id}}/next-read"
          }
        },
        {
          "name": "Create Article",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/articles",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"primary_category_id\": 1,\n  \"title\": \"مقالة تجريبية\",\n  \"slug\": \"trial-article-001\",\n  \"content\": \"محتوى المقالة كاملاً هنا...\",\n  \"excerpt\": \"ملخص قصير للمقالة\",\n  \"locale\": \"ar\",\n  \"is_breaking\": false,\n  \"is_premium\": false,\n  \"status\": \"draft\",\n  \"tags\": [],\n  \"secondary_categories\": []\n}"
            }
          }
        },
        {
          "name": "Update Article",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/articles/{{article_id}}",
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"title\": \"عنوان محدّث\",\n  \"status\": \"pending\"\n}"
            }
          }
        },
        {
          "name": "Delete Article",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/articles/{{article_id}}"
          }
        }
      ]
    },
    {
      "name": "Me",
      "item": [
        {
          "name": "Social Overview",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/me/social",
            "description": "Counts: saved_articles_count, following_count, followers_count (writer only)."
          }
        },
        {
          "name": "My Saved Articles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/me/social?type=saved&per_page=15&locale=",
              "host": ["{{base_url}}"],
              "path": ["me", "social"],
              "query": [
                { "key": "type", "value": "saved", "description": "saved | following | followers" },
                { "key": "per_page", "value": "15" },
                { "key": "locale", "value": "", "description": "ar | en (optional, saved only)" }
              ]
            }
          }
        },
        {
          "name": "My Following",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/me/social?type=following&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["me", "social"],
              "query": [
                { "key": "type", "value": "following" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "My Followers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/me/social?type=followers&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["me", "social"],
              "query": [
                { "key": "type", "value": "followers", "description": "Writer only — returns 403 for non-writers" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Toggle Save Article",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/articles/{{article_id}}/save",
            "description": "Toggle save. Response: `saved` (bool), `action` (`saved` | `unsaved`)."
          }
        },
        {
          "name": "Toggle Follow Writer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/writers/{{writer_id}}/follow",
            "description": "Toggle follow. Response: `following` (bool), `action` (`followed` | `unfollowed`)."
          }
        }
      ]
    },
    {
      "name": "Primary Categories",
      "item": [
        {
          "name": "List Primary Categories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/primary-categories"
          }
        },
        {
          "name": "Primary Category Filters",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/primary-categories/{{category_id}}/filters"
          }
        },
        {
          "name": "Primary Category Articles",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/primary-categories/{{category_id}}/articles?locale=ar&sort=latest&format=all&date_range=all&secondary=&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["primary-categories", "{{category_id}}", "articles"],
              "query": [
                { "key": "locale", "value": "ar", "description": "ar | en" },
                { "key": "sort", "value": "latest", "description": "latest | views | trending | oldest" },
                { "key": "format", "value": "all", "description": "all | breaking | premium | video" },
                { "key": "date_range", "value": "all", "description": "all | today | week | month" },
                { "key": "secondary", "value": "", "description": "Optional secondary category ID" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Show Primary Category",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/primary-categories/{{category_id}}"
          }
        },
        {
          "name": "Primary Category Trending Articles",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/primary-categories/{{category_id}}/trending-article?locale=ar&limit=6&secondary=",
              "host": ["{{base_url}}"],
              "path": ["primary-categories", "{{category_id}}", "trending-article"],
              "query": [
                { "key": "locale", "value": "ar" },
                { "key": "limit", "value": "6" },
                { "key": "secondary", "value": "", "description": "Optional secondary category ID under this primary" }
              ]
            }
          }
        },
        {
          "name": "Primary Category Editor Picks",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/primary-categories/{{category_id}}/editor-picks?locale=ar&limit=6&secondary=",
              "host": ["{{base_url}}"],
              "path": ["primary-categories", "{{category_id}}", "editor-picks"],
              "query": [
                { "key": "locale", "value": "ar" },
                { "key": "limit", "value": "6" },
                { "key": "secondary", "value": "", "description": "Optional secondary category ID under this primary" }
              ]
            }
          }
        },
        {
          "name": "Primary Category High-Performing Writers",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/primary-categories/{{category_id}}/writers?limit=5&secondary=",
              "host": ["{{base_url}}"],
              "path": ["primary-categories", "{{category_id}}", "writers"],
              "query": [
                { "key": "limit", "value": "5" },
                { "key": "secondary", "value": "", "description": "Optional secondary category ID under this primary" }
              ]
            }
          }
        },
        {
          "name": "List Secondary Categories of Primary",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
